# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local (docker-compose): mongodb://mongo:27017/slaycall
# Atlas:                  mongodb+srv://user:password@cluster.mongodb.net/slaycall
MONGODB_URI=mongodb://mongo:27017/slaycall

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local (docker-compose): redis://redis:6379
# Upstash / Redis Cloud:  rediss://:<password>@<host>:<port>
REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ACCESS_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:5173
